SECRET_KEY=replace-with-a-long-random-secret
SECURITY_PASSWORD_SALT=replace-with-a-different-long-random-secret
TICKET_TOKEN_MAX_AGE_SECONDS=2592000
APP_ENV=development
FORCE_HTTPS=false
SESSION_COOKIE_SECURE=false

DATABASE_URL=postgresql+psycopg2://medienscouts:medienscouts@localhost:5432/medienscouts
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=medienscouts
POSTGRES_USER=medienscouts
POSTGRES_PASSWORD=change-me
RATELIMIT_STORAGE_URI=redis://localhost:6379/1

SMTP_SERVER=smtp.web.de
SMTP_PORT=587
SMTP_USER=your_email
SMTP_PASSWORD=your_password

# Optional one-time initial admin bootstrap.
# Leave ADMIN_PASSWORD empty to avoid creating an initial admin automatically.
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=

GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=120
